---
import ogs from "open-graph-scraper";
import {
  closeSync,
  existsSync,
  mkdirSync,
  openSync,
  readFileSync,
  renameSync,
  unlinkSync,
  writeFileSync,
} from "node:fs";
import { fileURLToPath } from "node:url";
import { setTimeout } from "node:timers/promises";
import { createLogger, format, transports } from "winston";
const { combine, timestamp, printf, colorize } = format;

const myFormat = printf(({ level, message, timestamp }) => {
  return `${timestamp} [${level}]: ${message}`;
});

const logger = createLogger({
  format: combine(
    colorize(),
    timestamp({ format: "YYYY-MM-DD HH:mm:ss" }), // タイムスタンプを設定
    myFormat,
  ),
  transports: [new transports.Console()],
});

interface Props {
  url: string;
  title?: string;
  description?: string;
  image?: string;
  fixed?: boolean;
  url_amazon?: string;
  url_yahoo?: string;
  code_rakuten?: string;
  keyword_rakuten?: string;
}

interface RakutenAffiliateResponse {
  Items: Array<RakutenAffiliateItem>;
  count: number;
  first: number;
  hits: number;
  last: number;
  page: number;
  pageCount: number;
}

type RakutenAffiliateItem = {
  Item: {
    affiliateRate: number;
    affiliateUrl: string;
    availability: number;
    catchcopy: string;
    genreId: number;
    itemCaption: string;
    itemCode: number;
    itemName: string;
    itemPrice: number;
    itemUrl: string;
  };
};

interface RakutenKakakuNaviItems {
  Products: Array<RakutenKakakuNaviItem>;
  count: number;
}

type RakutenKakakuNaviItem = {
  affiliateUrl: string;
  productName: string;
};

const projectRoot = fileURLToPath(new URL('../../..', import.meta.url));
const cacheDirPath = `${projectRoot}/.astro`;
const cacheFilePath = `${cacheDirPath}/oglinkcard-rakuten-cache.json`;
const cacheLockPath = `${cacheFilePath}.lock`;

type CachedOGPData = {
  ogUrl?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: Array<{ url?: string }>;
};

const rakutenAffiliateCache = new Map<string, string | null>();
const rakutenKakakuNaviCache = new Map<string, string | null>();
const ogpDataCache = new Map<string, CachedOGPData | null>();

function loadRakutenCacheFile() {
  if (!existsSync(cacheFilePath)) {
    return;
  }

  try {
    const raw = readFileSync(cacheFilePath, "utf8");
    if (!raw) {
      return;
    }

    const parsed = JSON.parse(raw);
    if (parsed?.rakutenAffiliate && typeof parsed.rakutenAffiliate === "object") {
      for (const [key, value] of Object.entries(parsed.rakutenAffiliate)) {
        rakutenAffiliateCache.set(key, value as string | null);
      }
    }
    if (parsed?.rakutenKakakuNavi && typeof parsed.rakutenKakakuNavi === "object") {
      for (const [key, value] of Object.entries(parsed.rakutenKakakuNavi)) {
        rakutenKakakuNaviCache.set(key, value as string | null);
      }
    }
    if (parsed?.ogpData && typeof parsed.ogpData === "object") {
      for (const [key, value] of Object.entries(parsed.ogpData)) {
        ogpDataCache.set(key, value as CachedOGPData | null);
      }
    }
  } catch (error) {
    logger.warn("Failed to load Rakuten cache file: " + error);
  }
}

async function acquireCacheLock(retries = 50, delayMs = 100) {
  for (let attempt = 0; attempt < retries; attempt += 1) {
    try {
      return openSync(cacheLockPath, "wx");
    } catch (error: any) {
      if (error?.code !== "EEXIST") {
        throw error;
      }
      await setTimeout(delayMs);
    }
  }
  throw new Error("Could not acquire Rakuten cache lock after retries");
}

function releaseCacheLock(fd: number) {
  try {
    closeSync(fd);
  } catch (error) {
    logger.warn("Failed to close Rakuten cache lock fd: " + error);
  }
  try {
    unlinkSync(cacheLockPath);
  } catch (error) {
    logger.warn("Failed to remove Rakuten cache lock file: " + error);
  }
}

async function saveRakutenCacheFile() {
  let lockFd;
  try {
    lockFd = await acquireCacheLock();

    if (!existsSync(cacheDirPath)) {
      mkdirSync(cacheDirPath, { recursive: true });
    }

    let diskData: {
      rakutenAffiliate?: Record<string, string | null>;
      rakutenKakakuNavi?: Record<string, string | null>;
      ogpData?: Record<string, CachedOGPData | null>;
    } = {};

    if (existsSync(cacheFilePath)) {
      const raw = readFileSync(cacheFilePath, "utf8");
      if (raw) {
        diskData = JSON.parse(raw);
      }
    }

    const merged = {
      rakutenAffiliate: {
        ...(diskData.rakutenAffiliate ?? {}),
        ...Object.fromEntries(rakutenAffiliateCache),
      },
      rakutenKakakuNavi: {
        ...(diskData.rakutenKakakuNavi ?? {}),
        ...Object.fromEntries(rakutenKakakuNaviCache),
      },
      ogpData: {
        ...(diskData.ogpData ?? {}),
        ...Object.fromEntries(ogpDataCache),
      },
    };

    const tmpPath = `${cacheFilePath}.tmp`;
    writeFileSync(tmpPath, JSON.stringify(merged, null, 2), "utf8");
    renameSync(tmpPath, cacheFilePath);
  } catch (error) {
    logger.warn("Failed to save Rakuten cache file: " + error);
  } finally {
    if (typeof lockFd === "number") {
      releaseCacheLock(lockFd);
    }
  }
}

loadRakutenCacheFile();

let {
  url,
  title,
  description,
  image,
  fixed,
  url_amazon,
  url_yahoo,
  code_rakuten,
  keyword_rakuten,
} = Astro.props;

if (fixed == undefined) {
  fixed = false;
}

async function getOGPData(url: string) {
  if (ogpDataCache.has(url)) {
    return ogpDataCache.get(url) ?? {};
  }

  const userAgent =
    "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/127.0.0.0 Safari/537.36";
  const options = {
    url: url,
    timeout: 100,
    fetchOptions: { headers: { "user-agent": userAgent } },
  };
  try {
    const { result } = await ogs(options);
    const cacheValue: CachedOGPData = {
      ogUrl: result?.ogUrl,
      ogTitle: result?.ogTitle,
      ogDescription: result?.ogDescription,
      ogImage: Array.isArray(result?.ogImage)
        ? result.ogImage.map((image: any) => ({ url: image?.url }))
        : undefined,
    };
    ogpDataCache.set(url, cacheValue);
    await saveRakutenCacheFile();
    logger.info("fetched OGP LinkCard: " + result.ogUrl);
    return cacheValue;
  } catch (error) {
    logger.error("Error fetching Open Graph Data:", error);
    ogpDataCache.set(url, null);
    await saveRakutenCacheFile();
    return {};
  }
}

async function getRakutenAffiliateUrl(item_id: string) {
  if (rakutenAffiliateCache.has(item_id)) {
    return rakutenAffiliateCache.get(item_id) ?? null;
  }

  const api_url =
    "https://app.rakuten.co.jp/services/api/IchibaItem/Search/20220601";
  const [shop_code, item_code] = item_id.split("/");
  const application_id = import.meta.env.RAKUTEN_APPLICATION_ID;
  const affiliate_id = import.meta.env.RAKUTEN_AFFILIATE_ID;

  await setTimeout(Math.random() * 10000);

  const response = await fetch(
    api_url +
      "?" +
      new URLSearchParams({
        format: "json",
        keyword: item_code,
        shopCode: shop_code,
        applicationId: application_id,
        affiliateId: affiliate_id,
        sort: "+reviewAverage",
      }).toString(),
  );
  const data = await response.text();
  if (data == null) {
    logger.warning("getRakutenAffiliateUrl response data is null");
    rakutenAffiliateCache.set(item_id, null);
    await saveRakutenCacheFile();
    return null;
  }

  const json_response: RakutenAffiliateResponse = JSON.parse(data);
  if (json_response.count > 0) {
    const affiliateUrl = json_response.Items[0].Item.affiliateUrl;
    logger.info("fetched rakuten affiliate(by code): " + item_id);
    rakutenAffiliateCache.set(item_id, affiliateUrl);
    await saveRakutenCacheFile();
    return affiliateUrl;
  }

  logger.error(
    "fetching rakuten affiliate url process was failed(by code): " +
      item_id +
      " response: " +
      data,
  );
  rakutenAffiliateCache.set(item_id, null);
  await saveRakutenCacheFile();
  return null;
}

async function getRakutenKakakuNaviUrl(keyword: string) {
  if (rakutenKakakuNaviCache.has(keyword)) {
    return rakutenKakakuNaviCache.get(keyword) ?? null;
  }

  const api_url =
    "https://app.rakuten.co.jp/services/api/Product/Search/20170426";
  const application_id = import.meta.env.RAKUTEN_APPLICATION_ID;
  const affiliate_id = import.meta.env.RAKUTEN_AFFILIATE_ID;

  await setTimeout(Math.random() * 10000);

  const response = await fetch(
    api_url +
      "?" +
      new URLSearchParams({
        format: "json",
        formatVersion: "2",
        keyword: keyword,
        applicationId: application_id,
        affiliateId: affiliate_id,
        elements: "count,affiliateUrl,productName",
      }).toString(),
  );
  const data = await response.text();
  if (data == null) {
    rakutenKakakuNaviCache.set(keyword, null);
    await saveRakutenCacheFile();
    return null;
  }

  const json_response: RakutenKakakuNaviItems = JSON.parse(data);
  if (json_response.count > 0) {
    const affiliateUrl = json_response.Products[0].affiliateUrl;
    logger.info("fetched rakuten affiliate(by keyword): " + keyword);
    rakutenKakakuNaviCache.set(keyword, affiliateUrl);
    await saveRakutenCacheFile();
    return affiliateUrl;
  }

  logger.error(
    "fetching rakuten affiliate url process was failed(by keyword): " +
      keyword +
      " response: " +
      data,
  );
  rakutenKakakuNaviCache.set(keyword, null);
  await saveRakutenCacheFile();
  return null;
}

const ogpdata = await getOGPData(url);
if (fixed == false) {
  title = ogpdata?.ogTitle || "no title";
  image = ogpdata?.ogImage?.[0]?.url || undefined;
  description = ogpdata?.ogDescription || undefined;
}

let url_rakuten_affiliate = null;
if (code_rakuten != null) {
  url_rakuten_affiliate = await getRakutenAffiliateUrl(code_rakuten);
} else if (keyword_rakuten != null) {
  url_rakuten_affiliate = await getRakutenKakakuNaviUrl(keyword_rakuten);
}
---

<div class="oglc-container">
  <div class="oglc-content">
    <div class="oglc-left-container">
      <a href={url} class="oglc-title" target="_blank">{title}</a>
      <div class="oglc-description">{description && description}</div>
      <div class="oglc-buttons">
        {
          url_amazon && (
            <a href={url_amazon} class="oglc-btn" target="_blank">
              Amazon
            </a>
          )
        }
        {
          url_yahoo && (
            <a href={url_yahoo} class="oglc-btn" target="_blank">
              Yahoo!
            </a>
          )
        }
        {
          url_rakuten_affiliate && (
            <a href={url_rakuten_affiliate} class="oglc-btn" target="_blank">
              楽天
            </a>
          )
        }
      </div>
    </div>
    {image && <img class="oglc-image" src={image} alt="Image" />}
  </div>
</div>

<style>
  .oglc-container {
    display: flex;
    flex-direction: column;
    border: 1px solid #999;
    border-radius: 8px;
    padding: 16px;
    max-width: 800px;
    font-family: Arial, sans-serif;
  }

  .oglc-content {
    display: flex;
    align-items: flex-start;
    width: 100%;
  }

  .oglc-left-container {
    flex: 1;
    display: flex;
    flex-direction: column;
    margin-right: 16px;
  }

  .oglc-title {
    font-size: 1.2em;
    font-weight: bold;
    margin-bottom: 8px;
    color: #333;
    text-decoration: none;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .oglc-description {
    font-size: 0.9em;
    color: #555;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
  }

  .oglc-image {
    width: 120px;
    height: auto;
    object-fit: cover;
    flex-shrink: 0;
    margin-top: 0;
  }

  .oglc-buttons {
    display: flex;
    gap: 8px;
  }

  .oglc-btn {
    padding: 8px 12px;
    background-color: #0078ff;
    color: #fff !important;
    text-decoration: none;
    border-radius: 4px;
    font-size: 0.9em;
    text-align: center;
  }

  .oglc-btn:hover {
    background-color: #005bbf;
  }
</style>
